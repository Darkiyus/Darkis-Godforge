<section class="dg-manager dg-data-manager">
  <header><div><p class="eyebrow">{{ui.TOOLS}}</p><h2>{{ui.IMPORT_EXPORT}}</h2><p>{{ui.DATA_MANAGER_HINT}}</p></div><span class="dg-status">{{deityCount}} {{ui.DEITIES}}</span></header>
  <div class="dg-tool-grid">
    <article class="dg-tool-card"><i class="fas fa-file-export" aria-hidden="true"></i><h3>{{ui.EXPORT_PACKAGE}}</h3><p>{{ui.EXPORT_HINT}}</p><button type="button" class="dg-primary" data-action="export">{{ui.EXPORT}}</button></article>
    <article class="dg-tool-card"><i class="fas fa-file-import" aria-hidden="true"></i><h3>{{ui.IMPORT_PACKAGE}}</h3><p>{{ui.IMPORT_HINT}}</p><label class="dg-file-picker">{{ui.CHOOSE_FILE}}<input type="file" accept="application/json,.json" data-import-file></label></article>
  </div>
  {{#if error}}<div class="dg-validation dg-validation-error"><i class="fas fa-circle-exclamation" aria-hidden="true"></i><div><strong>{{ui.IMPORT_INVALID}}</strong><p>{{error}}</p></div></div>{{/if}}
  {{#if preview}}<section class="dg-import-preview"><h3>{{ui.IMPORT_PREVIEW}}</h3><div class="dg-stat-grid"><article><strong>{{preview.total}}</strong><span>{{ui.DEITIES}}</span></article><article><strong>{{preview.created}}</strong><span>{{ui.NEW_CONTENT}}</span></article><article><strong>{{preview.updated}}</strong><span>{{ui.UPDATED_CONTENT}}</span></article><article><strong>{{preview.tables}}</strong><span>{{ui.RANDOM_TABLES}}</span></article><article><strong>{{preview.wheels}}</strong><span>{{ui.FORTUNE_WHEELS}}</span></article></div><p>{{ui.IMPORT_APPLY_HINT}}</p><button type="button" class="dg-primary" data-action="apply-import">{{ui.APPLY_IMPORT}}</button></section>{{/if}}
</section>
