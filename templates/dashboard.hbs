<header class="dg-hero"><img src="logo.png" alt="{{ui.TITLE}}"><div><p class="eyebrow">{{ui.TITLE}}</p><h1>{{ui.TAGLINE}}</h1><p class="muted">{{ui.SUBTITLE}}</p></div><div class="dg-hero-actions"><button class="dg-secondary" data-action="codex">{{ui.CODEX}}</button><button class="dg-primary" data-action="create">＋ {{ui.CREATE}}</button></div></header><main><section class="dg-panel"><div class="dg-section-title"><h2>{{ui.MY_DEITIES}}</h2><span>{{deities.length}} {{ui.ENTRIES}}</span></div><div class="dg-grid">{{#each deities}}<article class="dg-card" data-deity="{{id}}"><div class="dg-card-art"><img src="{{image}}" alt=""></div><h3>{{name}}</h3><p>{{title}}</p><div class="dg-tags">{{#each domains}}<span>{{this}}</span>{{/each}}</div></article>{{/each}}<button class="dg-card dg-add" data-action="create"><span>＋</span><strong>{{ui.CREATE}}</strong></button></div></section><section class="dg-stats"><div><strong>{{stats.deities}}</strong><span>{{ui.MY_DEITIES}}</span></div><div><strong>{{stats.sanctuaries}}</strong><span>{{ui.SANCTUARIES}}</span></div><div><strong>{{stats.bonuses}}</strong><span>{{ui.PASSIVE_BONUS}}</span></div><div><strong>{{stats.abilities}}</strong><span>{{ui.ABILITIES}}</span></div></section></main>
