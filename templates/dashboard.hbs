<div class="dg-app-shell" tabindex="-1">
  <aside class="dg-sidebar" aria-label="{{ui.TITLE}}">
    <div class="dg-brand"><img src="modules/darkis-godforge/assets/logo.png" alt="{{ui.TITLE}}"></div>
    <nav>
      <p>{{ui.OVERVIEW}}</p>
      <button class="{{#if nav.overview}}active{{/if}}" type="button" data-section="overview"><i class="fas fa-table-cells-large" aria-hidden="true"></i><span>{{ui.OVERVIEW}}</span></button>
      <button class="{{#if nav.deities}}active{{/if}}" type="button" data-section="deities"><i class="fas fa-wand-magic-sparkles" aria-hidden="true"></i><span>{{ui.DEITIES}}</span><b>{{stats.deities}}</b></button>
      <button class="{{#if nav.pantheons}}active{{/if}}" type="button" data-section="pantheons"><i class="fas fa-landmark" aria-hidden="true"></i><span>{{ui.PANTHEONS}}</span><b>{{stats.pantheons}}</b></button>
      <button class="{{#if nav.abilities}}active{{/if}}" type="button" data-section="abilities"><i class="fas fa-bolt" aria-hidden="true"></i><span>{{ui.DIVINE_WONDERS}}</span><b>{{stats.abilities}}</b></button>
      <button class="{{#if nav.bonuses}}active{{/if}}" type="button" data-section="bonuses"><i class="fas fa-shield-halved" aria-hidden="true"></i><span>{{ui.PASSIVE_BONUSES}}</span><b>{{stats.bonuses}}</b></button>
      <button type="button" data-manager="random" data-manager-mode="tables"><i class="fas fa-dice-d20" aria-hidden="true"></i><span>{{ui.RANDOM_TABLES}}</span></button>
      <button type="button" data-manager="random" data-manager-mode="wheels"><i class="fas fa-dharmachakra" aria-hidden="true"></i><span>{{ui.FORTUNE_WHEELS}}</span></button>
      <p>{{ui.INTEGRATION}}</p>
      <button type="button" data-manager="replacements"><i class="fas fa-code-compare" aria-hidden="true"></i><span>{{ui.REPLACEMENTS}}</span></button>
      <button type="button" data-manager="characters"><i class="fas fa-users" aria-hidden="true"></i><span>{{ui.CHARACTERS}}</span><b>{{stats.assignedActors}}</b></button>
      <button type="button" data-action="codex"><i class="fas fa-book-open" aria-hidden="true"></i><span>{{ui.CODEX}}</span></button>
      <button type="button" data-action="player-preview"><i class="fas fa-eye" aria-hidden="true"></i><span>{{ui.PLAYER_VIEW}}</span></button>
      <p>{{ui.TOOLS}}</p>
      <button type="button" data-manager="random" data-manager-mode="test"><i class="fas fa-flask" aria-hidden="true"></i><span>{{ui.TEST_LAB}}</span></button>
      <button type="button" data-manager="data" data-manager-mode="transfer"><i class="fas fa-file-import" aria-hidden="true"></i><span>{{ui.IMPORT_EXPORT}}</span></button>
      <button type="button" data-manager="data" data-manager-mode="migration"><i class="fas fa-clock-rotate-left" aria-hidden="true"></i><span>{{ui.MIGRATIONS}}</span></button>
      <button type="button" disabled title="{{ui.PLANNED}}"><i class="fas fa-list-check" aria-hidden="true"></i><span>{{ui.AUDIT_LOG}}</span></button>
    </nav>
    <button type="button" class="dg-sidebar-footer" data-action="settings"><i class="fas fa-gear" aria-hidden="true"></i><span>{{ui.SETTINGS}}</span></button>
  </aside>

  <main class="dg-dashboard-main">
    <header class="dg-hero">
      <div class="dg-hero-shade"></div>
      <div class="dg-hero-copy"><h1>{{ui.TAGLINE}}</h1></div>
      <div class="dg-hero-actions"><button class="dg-secondary" data-action="codex"><i class="fas fa-book-open" aria-hidden="true"></i> {{ui.CODEX}}</button><button class="dg-primary" data-action="create"><i class="fas fa-plus" aria-hidden="true"></i> {{ui.CREATE}}</button></div>
    </header>

    <div class="dg-search"><i class="fas fa-magnifying-glass" aria-hidden="true"></i><input data-search value="{{searchTerm}}" placeholder="{{ui.SEARCH}}" aria-label="{{ui.SEARCH}}"><kbd>Ctrl K</kbd><button type="button" class="dg-context-toggle" data-action="toggle-context" title="{{ui.QUICK_ACCESS}}"><i class="fas fa-bars-staggered" aria-hidden="true"></i></button></div>

    <section class="dg-dashboard-section">
      <div class="dg-section-title"><div><p class="eyebrow">{{ui.DEITIES}}</p><h2>{{ui.MY_DEITIES}}</h2></div><span>{{deities.length}} {{ui.ENTRIES}}</span></div>
      {{#if deities.length}}
        <div class="dg-deity-grid">
          {{#each deities}}
            <button class="dg-deity-card" type="button" data-deity="{{id}}">
              <span class="dg-card-art"><img src="{{image}}" alt="" style="object-fit:{{imageFit}};object-position:{{imagePosition}}"><i class="dg-pantheon-gem" aria-hidden="true"></i><em class="dg-status dg-status-{{status}}">{{statusLabel}}</em></span>
              <span class="dg-card-copy"><strong>{{name}}</strong><small>{{title}}</small><span class="dg-tags">{{#each domains}}<i>{{this}}</i>{{/each}}</span></span>
            </button>
          {{/each}}
        </div>
      {{else}}
        {{#if hasAnyDeities}}
          <div class="dg-empty-state"><i class="fas fa-magnifying-glass" aria-hidden="true"></i><h3>{{ui.NO_RESULTS}}</h3></div>
        {{else}}
          <div class="dg-empty-state"><i class="fas fa-hammer" aria-hidden="true"></i><h3>{{ui.EMPTY_TITLE}}</h3><p>{{ui.EMPTY_HINT}}</p><div><button class="dg-primary" data-action="create">{{ui.CREATE}}</button><button class="dg-secondary" data-manager="data">{{ui.IMPORT}}</button></div></div>
        {{/if}}
      {{/if}}
    </section>

    <section class="dg-stat-grid" aria-label="{{ui.OVERVIEW}}">
      <article><i class="fas fa-wand-magic-sparkles" aria-hidden="true"></i><strong>{{stats.deities}}</strong><span>{{ui.DEITIES}}</span></article>
      <article><i class="fas fa-circle-check" aria-hidden="true"></i><strong>{{stats.published}}</strong><span>{{ui.PUBLISHED}}</span></article>
      <article><i class="fas fa-shield-halved" aria-hidden="true"></i><strong>{{stats.bonuses}}</strong><span>{{ui.PASSIVE_BONUSES}}</span></article>
      <article><i class="fas fa-bolt" aria-hidden="true"></i><strong>{{stats.abilities}}</strong><span>{{ui.DIVINE_WONDERS}}</span></article>
      <article><i class="fas fa-triangle-exclamation" aria-hidden="true"></i><strong>{{stats.invalid}}</strong><span>{{ui.INVALID}}</span></article>
      <article><i class="fas fa-users" aria-hidden="true"></i><strong>{{stats.assignedActors}}</strong><span>{{ui.ASSIGNED_CHARACTERS}}</span></article>
    </section>

    <section class="dg-dashboard-section dg-recent" data-section-target="recent">
      <div class="dg-section-title"><h2>{{ui.RECENTLY_EDITED}}</h2></div>
      <div class="dg-table-wrap"><table><thead><tr><th>{{ui.NAME}}</th><th>{{ui.TYPE}}</th><th>{{ui.STATUS}}</th><th>{{ui.LAST_CHANGED}}</th></tr></thead><tbody>{{#each recent}}<tr data-deity="{{id}}"><td><strong>{{name}}</strong><small>{{title}}</small></td><td>{{../ui.DEITIES}}</td><td><span class="dg-status dg-status-{{status}}">{{statusLabel}}</span></td><td>{{updatedLabel}}</td></tr>{{/each}}</tbody></table></div>
    </section>

    <div class="dg-small-window-note"><i class="fas fa-up-right-and-down-left-from-center" aria-hidden="true"></i> {{ui.LARGER_WINDOW}}</div>
  </main>

  <aside class="dg-context-rail">
    <section class="dg-quick-access"><h2>{{ui.QUICK_ACCESS}}</h2><div class="dg-quick-list"><button type="button" data-action="create"><i class="fas fa-plus" aria-hidden="true"></i><strong>{{ui.CREATE}}</strong></button><button type="button" data-action="player-preview"><i class="fas fa-eye" aria-hidden="true"></i><strong>{{ui.PLAYER_PREVIEW}}</strong></button><button type="button" data-manager="data" data-manager-mode="transfer"><i class="fas fa-file-import" aria-hidden="true"></i><strong>{{ui.IMPORT_EXPORT}}</strong></button></div></section>
    <section><h2>{{ui.SYSTEM_STATUS}}</h2><dl><div><dt>Foundry</dt><dd>{{systemInfo.foundry}}</dd></div><div><dt>{{ui.SYSTEM}}</dt><dd>{{systemInfo.system}} {{systemInfo.systemVersion}}</dd></div><div><dt>GodForge</dt><dd>{{systemInfo.moduleVersion}}</dd></div><div><dt>{{ui.ADAPTER}}</dt><dd>{{systemInfo.adapter}}</dd></div><div><dt>{{ui.SCHEMA}}</dt><dd>{{systemInfo.schema}}</dd></div></dl><span class="dg-health"><i class="fas fa-circle-check" aria-hidden="true"></i> {{ui.DIAGNOSTICS_OK}}</span></section>
  </aside>
</div>
