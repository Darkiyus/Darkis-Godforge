<section class="dg-manager">
  <header><div><p class="eyebrow">{{ui.INTEGRATION}}</p><h2>{{ui.CHARACTERS}}</h2><p>{{ui.CHARACTER_MANAGER_HINT}}</p></div></header>
  <form class="dg-character-assignment"><div class="dg-form-grid"><label>{{ui.CHARACTER}}<select name="actorId" required><option value="">—</option>{{#each actors}}<option value="{{id}}">{{name}} · {{deityName}}</option>{{/each}}</select></label><label>{{ui.DEITIES}}<select name="deityId" required><option value="">—</option>{{#each deities}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label></div>{{#each deities}}<section data-deity-choices="{{id}}" hidden>{{#each choiceGroups}}<fieldset><legend>{{label}} · {{../../ui.PICK_COUNT}} {{pick}}</legend>{{#each options}}<label><input type="checkbox" data-group="{{../id}}" value="{{id}}"> {{label}}</label>{{/each}}</fieldset>{{/each}}</section>{{/each}}<button class="dg-primary" type="submit">{{ui.ASSIGN_DEITY}}</button></form>
  <section class="dg-editor-section"><div class="dg-section-title"><h3>{{ui.ASSIGNED_CHARACTERS}}</h3><span>{{actors.length}} {{ui.ENTRIES}}</span></div><div class="dg-manager-list">{{#each actors}}<article><i class="fas fa-user" aria-hidden="true"></i><span><strong>{{name}}</strong><small>{{deityName}}</small></span></article>{{/each}}</div></section>
</section>
