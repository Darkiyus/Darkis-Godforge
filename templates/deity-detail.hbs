<section class="dg-detail-grid"><div class="dg-detail-art"><img src="{{deity.image}}" alt=""></div><div><p class="eyebrow">{{ui.TITLE}}</p><h2>{{deity.name}}</h2><p class="muted">{{deity.title}}</p><p>{{deity.description}}</p><h3>{{ui.DOMAINS}}</h3><div class="dg-list">{{#each deity.domains}}<div>{{this}}</div>{{/each}}</div><h3>{{ui.PASSIVE_BONUS}}</h3><div class="dg-list">{{#each deity.passiveBonuses}}<div>{{name}}<span>{{value}}</span></div>{{/each}}</div><h3>{{ui.ABILITIES}}</h3><div class="dg-list">{{#each deity.abilities}}<div><strong>{{name}}</strong><span>{{description}}</span></div>{{/each}}</div></div></section>
