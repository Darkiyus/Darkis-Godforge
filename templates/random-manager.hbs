<section class="dg-manager dg-random-manager">
  {{#if error}}<div class="dg-validation dg-validation-error"><i class="fas fa-triangle-exclamation" aria-hidden="true"></i><p>{{error}}</p></div>{{/if}}
  <header><div><p class="eyebrow">{{ui.TOOLS}}</p><h2>{{ui.RANDOM_AND_WHEELS}}</h2><p>{{ui.RANDOM_MANAGER_HINT}}</p></div>{{#if result}}<div class="dg-wheel-result"><i class="fas fa-dharmachakra" aria-hidden="true"></i><span><strong>{{result.label}}</strong><small>{{result.description}}</small></span></div>{{/if}}</header>
  <div class="dg-random-layout">
    <section class="dg-editor-section"><div class="dg-section-title"><h3>{{ui.NEW_RANDOM_TABLE}}</h3></div><form data-table-form><div class="dg-form-grid dg-form-grid-3"><label>{{ui.NAME}}<input name="table.name" required></label><label>{{ui.DICE_FORMULA}}<input name="table.formula" value="1d100" required></label><label>{{ui.VISIBILITY}}<select name="table.visibility"><option value="public">{{ui.VIS_PUBLIC}}</option><option value="followers">{{ui.VIS_FOLLOWERS}}</option><option value="gm">{{ui.VIS_GM}}</option></select></label></div><div class="dg-random-entry-head"><strong>{{ui.RESULT_ENTRIES}}</strong><button type="button" class="dg-secondary" data-action="add-entry">{{ui.ADD_RESULT}}</button></div><div class="dg-editor-list" data-entry-list></div><button class="dg-primary" type="submit">{{ui.SAVE_TABLE}}</button></form></section>
    <section class="dg-editor-section"><div class="dg-section-title"><h3>{{ui.NEW_FORTUNE_WHEEL}}</h3></div><form data-wheel-form><div class="dg-form-grid"><label>{{ui.NAME}}<input name="wheel.name" required></label><label>{{ui.LINKED_TABLE}}<select name="wheel.tableId" required><option value="">—</option>{{#each tables}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label><label>{{ui.ANIMATION_DURATION}}<input type="number" min="1" max="30" name="wheel.duration" value="6"></label><label>{{ui.MINIMUM_SPINS}}<input type="number" min="1" max="30" name="wheel.minimumSpins" value="5"></label><label>{{ui.VISIBILITY}}<select name="wheel.visibility"><option value="public">{{ui.VIS_PUBLIC}}</option><option value="owner">{{ui.VIS_OWNER}}</option><option value="gm">{{ui.VIS_GM}}</option></select></label></div><button class="dg-primary" type="submit">{{ui.SAVE_WHEEL}}</button></form></section>
  </div>
  <section class="dg-editor-section"><div class="dg-section-title"><h3>{{ui.RANDOM_TABLES}}</h3><span>{{tables.length}} {{ui.ENTRIES}}</span></div>{{#if tables.length}}<div class="dg-manager-list">{{#each tables}}<article><i class="fas fa-dice-d20" aria-hidden="true"></i><span><strong>{{name}}</strong><small>{{formula}} · {{entries.length}} {{../ui.RESULT_ENTRIES}}</small></span><button class="dg-secondary" type="button" data-test-table="{{id}}">{{../ui.TEST_DRAW}}</button></article>{{/each}}</div>{{else}}<p class="muted">{{ui.NO_RANDOM_TABLES}}</p>{{/if}}</section>
  <section class="dg-editor-section"><div class="dg-section-title"><h3>{{ui.FORTUNE_WHEELS}}</h3><span>{{wheels.length}} {{ui.ENTRIES}}</span></div>{{#if wheels.length}}<div class="dg-manager-list">{{#each wheels}}<article><i class="fas fa-dharmachakra" aria-hidden="true"></i><span><strong>{{name}}</strong><small>{{tableName}}</small></span><button class="dg-secondary" type="button" data-test-wheel="{{id}}">{{../ui.TEST_SPIN}}</button></article>{{/each}}</div>{{else}}<p class="muted">{{ui.NO_FORTUNE_WHEELS}}</p>{{/if}}</section>
  <template data-template="random-entry"><article class="dg-random-entry" data-entry-row><input name="entry.label" required placeholder="{{ui.RESULT_TITLE}}"><input type="number" min="0.01" step="0.01" name="entry.weight" value="1" required><select name="entry.category"><option value="jackpot">{{ui.CATEGORY_JACKPOT}}</option><option value="positive">{{ui.CATEGORY_POSITIVE}}</option><option value="neutral" selected>{{ui.CATEGORY_NEUTRAL}}</option><option value="negative">{{ui.CATEGORY_NEGATIVE}}</option><option value="catastrophic">{{ui.CATEGORY_CATASTROPHIC}}</option></select><input name="entry.description" placeholder="{{ui.DESCRIPTION}}"><button type="button" data-action="remove-entry" title="{{ui.REMOVE}}"><i class="fas fa-trash" aria-hidden="true"></i></button></article></template>
</section>
