<section class="dg-codex"><div class="dg-codex-title"><p class="eyebrow">{{ui.TITLE}}</p><h2>{{ui.CODEX}}</h2></div><div class="dg-codex-toolbar"><input data-search placeholder="{{ui.SEARCH}}"><select data-filter><option value="">{{ui.ALL_DOMAINS}}</option>{{#each domains}}<option value="{{this}}">{{this}}</option>{{/each}}</select></div><div class="dg-codex-list">{{#each deities}}<article class="dg-codex-entry"><div><h3>{{name}}</h3><p>{{title}}</p></div><span>{{domains}}</span></article>{{/each}}</div></section>
