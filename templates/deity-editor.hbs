<section class="dg-editor"><div class="dg-editor-header"><p class="eyebrow">{{ui.TITLE}}</p><h2>{{ui.NEW_DEITY}}</h2><p class="muted">{{ui.NEW_DEITY_HINT}}</p></div><form><label>{{ui.NAME}}<input name="name" required maxlength="80" placeholder="{{ui.NEW_DEITY_PLACEHOLDER}}"></label><label>{{ui.TITLE_FIELD}}<input name="title" required maxlength="120" placeholder="{{ui.TITLE_PLACEHOLDER}}"></label><label>{{ui.DESCRIPTION}}<textarea name="description" required maxlength="1000" rows="4"></textarea></label><label>{{ui.DOMAINS}}<input name="domains" required placeholder="{{ui.DOMAINS_PLACEHOLDER}}"></label><label>{{ui.ALIGNMENT}}<input name="alignment"></label><div class="dg-editor-actions"><button type="button" data-action="close">{{ui.CANCEL}}</button><button class="dg-primary" type="submit">{{ui.SAVE}}</button></div></form></section>
